{
  "name": "twenty-eight-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "hooks:install": "git config core.hooksPath .githooks",
    "clean:dist": "find . -type d -name dist -prune -exec rm -rf {} + && find . -type f -name '*.tsbuildinfo' -delete",
    "clean:node_modules": "find . -type d -name node_modules -prune -exec rm -rf {} +"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.5.1",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.24.1",
    "vitest": "^3.0.7"
  }
}
